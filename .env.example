# AI provider: "gemini", "modelscope", or "cloudflare" (code defaults to modelscope when unset)
AI_PROVIDER=modelscope

# Google Gemini - required when AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# ModelScope - required when AI_PROVIDER=modelscope
# Get your token at: https://modelscope.cn/my/myaccesstoken
MODELSCOPE_API_KEY=
MODELSCOPE_MODEL=Qwen/Qwen3-VL-30B-A3B-Instruct

# Cloudflare Workers AI - required when AI_PROVIDER=cloudflare
# Create a token from Workers AI > Use REST API in the Cloudflare dashboard
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_MODEL=@cf/meta/llama-3.2-11b-vision-instruct

# Optional - only needed if you want history / cloud image storage
POSTGRES_URL=
BLOB_READ_WRITE_TOKEN=

# Amazon Listing audit
# Text provider for parse + audit: gemini (default) | modelscope
AMAZON_TEXT_PROVIDER=gemini
# ASIN fetch: Rainforest (optional) or page scrape + LLM parse (needs GEMINI_API_KEY or MODELSCOPE_API_KEY)
RAINFOREST_API_KEY=
AMAZON_MARKETPLACE_DEFAULT=US
MODELSCOPE_TEXT_MODEL=
